# =============================================================================
# Mobile Selling Chatbot Vietnamese — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM — Anthropic Claude
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Model to use for chat completions
# Options: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6

# Maximum tokens per response
CLAUDE_MAX_TOKENS=1024

# -----------------------------------------------------------------------------
# Database — PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=chatbot
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot_secret

# Full connection URL (overrides individual fields above when set)
DATABASE_URL=postgresql://chatbot:chatbot_secret@localhost:5432/chatbot

# -----------------------------------------------------------------------------
# Cache — Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0

# Full connection URL
REDIS_URL=redis://:redis_secret@localhost:6379/0

# Session TTL in seconds (default: 24 hours)
SESSION_TTL=86400

# -----------------------------------------------------------------------------
# Vector Store — Qdrant
# -----------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=qdrant_secret

# Full URL
QDRANT_URL=http://localhost:6333

# Name of the Qdrant collection for product embeddings
QDRANT_COLLECTION=mobile_products

# -----------------------------------------------------------------------------
# Embeddings
# -----------------------------------------------------------------------------
# Sentence-transformers model for generating product embeddings
# Recommended multilingual model for Vietnamese text support
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Number of top-k results to retrieve from Qdrant per query
RETRIEVAL_TOP_K=5

# Minimum similarity score threshold (0.0 – 1.0)
RETRIEVAL_SCORE_THRESHOLD=0.6

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Secret key for signing JWT tokens / session tokens
SECRET_KEY=change_me_to_a_random_64_char_hex_string

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Frontend — Streamlit
# -----------------------------------------------------------------------------
BACKEND_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Data Ingestion
# -----------------------------------------------------------------------------
# Path to the product catalogue CSV / JSON used by `make ingest`
PRODUCT_DATA_PATH=data/products.json

# Batch size when upserting vectors into Qdrant
INGEST_BATCH_SIZE=50
